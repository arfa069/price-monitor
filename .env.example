# Database
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@localhost:5432/pricemonitor

# Redis
REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=your_redis_password

# Feishu Webhook
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_TOKEN_HERE

# JD Cookie (full session cookies)
JD_COOKIE=your_jd_cookie_here

# Crawler settings
DATA_RETENTION_DAYS=365

# Proxy settings (optional)
# CRAWL_PROXY_URL=http://user:pass@host:port
# CRAWL_PROXY_ENABLED=false

# CDP mode: connect to existing browser with JD login session
CDP_ENABLED=false
CDP_URL=http://127.0.0.1:9222

# App settings
APP_NAME=Price Monitor
DEBUG=false

# Job match LLM
JOB_MATCH_PROVIDER=minimax
JOB_MATCH_MODEL=MiniMax-M2.7
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_API_KEY=your_minimax_api_key_here

# JWT settings (MUST be changed from default)
JWT_SECRET_KEY=change-this-to-a-random-secret-key
