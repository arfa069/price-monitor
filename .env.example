# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/pricemonitor

# Redis
REDIS_URL=redis://redis:6379/0

# Feishu Webhook (replace with your actual webhook URL)
FEISHU_WEBHOOK_URL=

# Crawler settings
CRAWL_FREQUENCY_HOURS=1
DATA_RETENTION_DAYS=365

# App settings
APP_NAME=Price Monitor
DEBUG=false
